  1:Name            U1_IDE;
  2:Partno          CA0001;
  3:Revision        01;
  4:Date            03/2026;
  5:Designer        Emil;
  6:Company         None;
  7:Location        None;
  8:Assembly        None;
  9:Device          g22v10;
 10:
 11:Pin 1 = clk;      /* not used */
 12:Pin 2 = rtcin;
 13:Pin 3 = !iorq;
 14:Pin 4 = !rd;
 15:Pin 5 = !wr;
 16:Pin 6 = !m1;      /* not used */
 17:Pin 7 = !reset;   /* not used */
 18:Pin [16,15,14,13,11,10,9,8] = [a7..a0];
 19:field io_addr = [a7..a0];
 20:Pin 23 = !rtcwr;   /* Chip select for write to RTC  */
 21:Pin 22 = rtcrd;   /* Chip select for read from RTC */
 22:Pin 21 = d0;
 23:Pin 20 = rtcio;
 24:Pin 19 = rtcwe;   /* input from 74hct174 */
 25:Pin 18 = !iord;   /* chip select for read from switches */
 26:Pin 17 = !iowr;   /* chip select for write to LEDs      */
 27:
 28:d0 = rtcio;      /* d0 passes through rtcio during rtcrd */
 29:d0.oe = rtcrd;
 30:
 31:rtcio = rtcin;   /* rtcio passes rtcin when during rtcwe */
 32:rtcio.oe = !rtcwe;
 33:
 34:rtcwr = iorq & wr & io_addr:[C0];   /* RTC is at $C0 (the default for RomWBW */
 35:rtcrd = iorq & rd & io_addr:[C0];
 36:
 37:iowr = iorq & wr & io_addr:[C1];    /* IO is at $C1 as opposed to standard port of $00 */
 38:iord = iorq & rd & io_addr:[C1];
 39:
 40:
 41:



