%SIGNAL
PIN   3 =  a0 
PIN   4 =  a1 
PIN   5 =  a2 
PIN   6 =  a3 
PIN   7 =  a4 
PIN   8 =  a5 
PIN   9 =  a6 
PIN  11 =  a7 
PIN   1 =  clk 
PIN  19 = !cs0 
PIN   2 = !iorq 
%END

%FIELD
FIELD io_addr = a7,a6,a5,a4,a3,a2,a1,a0
%END

%EQUATION
cs0 =>
    !a2 & !a3 & !a4 & a5 & !a6 & !a7 & !iorq

%END
