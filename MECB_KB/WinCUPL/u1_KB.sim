%SIGNAL
PIN   2 =  a0 
PIN   3 =  a1 
PIN   4 =  a2 
PIN   5 =  a3 
PIN   6 =  a4 
PIN   7 =  a5 
PIN   8 =  a6 
PIN   9 =  a7 
PIN  18 =  addr 
PIN  19 = !cs0 
PIN   1 = !iorq 
%END

%FIELD
FIELD io_addr = a7,a6,a5,a4,a3,a2,a1,a0
%END

%EQUATION
addr =>
    a2

cs0 =>
    !a0 & !a1 & !a3 & !a4 & a5 & a6 & !a7 & !iorq

%END
