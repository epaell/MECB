 21:Pin 11 = ss0;   /* not used */
 22:
 23:/* Pins 13 and 14 are unused at the moment */
 24:Pin 15 = clk8;
 25:Pin 16 = clk4;
 26:Pin 17 = clk2;
 27:Pin 18 = int;
 28:Pin 19 = nmi;
 29:Pin 20 = ecbreset;
 30:Pin 21 = ecbiorq;
 31:Pin 22 = csram;
 32:Pin 23 = csrom;
 33:
 34:int = !ecbint;
 35:nmi = !ecbnmi;
 36:ecbreset = !reset;
 37:ecbiorq = !m;
 38:csram = !(!m & !a19);
 39:csrom = !(!m & a19);
 40:clk2.d = !clk2;
 41:clk4.d = clk4 $ clk2;
 42:clk8.d = clk8 $ (clk2 & clk4);
