 13:Pin 3 = ecbnmi;
 14:Pin 4 = ecbint;
 15:Pin 5 = ecbrd;
 16:Pin 6 = ecbwr; 
 17:Pin 7 = a19;
 18:Pin 8 = reset;
 19:Pin 9 = den;    /* not used */
