  5:Designer        Emil;
  6:Company         None;
  7:Location        None;
  8:Assembly        None;
  9:Device          g22v10;
 10:
 11:Pin 1 = clk;      /* not used */
 12:Pin 3 = !iorq;
 13:Pin 4 = !rd;
 14:Pin 5 = !wr;
 15:Pin 6 = !m1;      /* not used */
 16:Pin 7 = !reset;   /* not used */
 17:Pin [16,15,14,13,11,10,9,8] = [a7..a0];
 18:field io_addr = [a7..a0];
 19:Pin 23 = !sidcs1;   /* Chip select for SID1 */
 20:Pin 22 = !sidcs2;   /* Chip select for SID2 */
 21:Pin 21 = !sidaddr;
 22:
 23:/* If directly using CPU address lines */
 24:sidcs1 = iorq & io_addr:[A0..BF];
 25:sidcs2 = iorq & io_addr:[E0..FF];
 26:sidaddr = 'b'0;              /* disable address latch */
 27:
 28:/* If using latch to hold address lines */
 29:/* sidcs1 = iorq & io_addr:[A1]; */ /* SID write goes to address specified in latch */
 30:/* sidcs2 = iorq & io_addr:[A2]; */
 31:/* sidaddr = iorq & wr & io_addr:[A0]; */  /* Latch write to set up address lines */
 32:
