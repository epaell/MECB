 10:
 11:Pin 1 = sysclk;
 12:Pin 2 = mreq;
 13:Pin 3 = iorq;
 14:Pin 4 = ecbrd;
 15:Pin 5 = ecbwr;
 16:Pin 6 = a19; 
 17:Pin 7 = reset;
 18:Pin 8 = m1;
 19:Pin 9 = a2;
 20:Pin 10 = a3;
 21:Pin 11 = a4;
 22:
 23:/* Pins 13 and 14 are unused at the moment */
 24:Pin 13 = a5;
 25:Pin 14 = a6;
 26:Pin 15 = a7;
 27:Pin 16 = ecbmreq;
 28:Pin 17 = ecbiorq;
 29:Pin 18 = clk4;
 30:Pin 19 = clk2;
 31:Pin 20 = pagewr;
 32:Pin 21 = pgenwr;
 33:Pin 22 = csram;
 34:Pin 23 = csrom;
 35:
 36:csrom = !(!mreq & !a19);
 37:csram = !(!mreq & a19);
 38:pagewr = !(!iorq & m1 & !a7 & a6 & a5 & a4 & a3 & !a2 & !ecbwr); /* 0x0111 10xx = 78-7B */
 39:pgenwr = !(!iorq & m1 & !a7 & a6 & a5 & a4 & a3 & a2  & !ecbwr); /* 0x0111 11xx = 7C-7F */
 40:clk2.d = !clk2;
 41:clk4.d = clk4 $ clk2;
 42:ecbiorq = !(m1 & !iorq);
 43:

